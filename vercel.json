{
  "version": 2,
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "node_modules/@jimp/plugin-print/fonts/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.ts"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
