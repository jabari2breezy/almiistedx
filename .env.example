# Mailchimp Credentials
# API Key: e.g. abc123def456ghi789-us1
MAILCHIMP_API_KEY=
# Audience ID: found in Settings -> Audience name and defaults
MAILCHIMP_AUDIENCE_ID=
# Server Prefix: the 'usX' part of your API key (e.g. us1)
MAILCHIMP_SERVER_PREFIX=

# Resend Credentials (for administrative notifications)
RESEND_API_KEY=
